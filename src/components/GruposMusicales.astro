<!-- ═══════════════════════════════════════════════════════════ --><!-- 🎶 SECCIÓN: GRUPOS MUSICALES                                --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE GRUPOS MUSICALES -->
        <div class="flex justify-center">
            <div class="relative w-full max-w-md" id="card-grupos-musicales">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-grupos">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-grupos"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo grupos musicales"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Contenido de la card -->
                    <div class="relative px-6 pt-16 pb-10 z-10">
                        <!-- TÍTULO -->
                        <div class="text-center mb-2" id="titulo-grupos">
                            <h2
                                class="font-great-vibes text-[2.25rem] text-[#122a4d]"
                            >
                                Grupos Musicales
                            </h2>
                        </div>

                        <p
                            class="font-crimson text-base text-[#122a4d]/70 text-center mb-6"
                            id="subtitulo-grupos"
                        >
                            Música en vivo para celebrar toda la noche
                        </p>

                        <!-- SEPARADOR -->
                        <div
                            class="flex items-center justify-center gap-3 mb-6"
                            id="separador-grupos"
                        >
                            <div class="flex-1 h-px bg-[#122a4d]/20"></div>
                            <span class="text-[#c9a961] text-base">✦</span>
                            <div class="flex-1 h-px bg-[#122a4d]/20"></div>
                        </div>

                        <!-- GRID DE GRUPOS (2 COLUMNAS) -->
                        <div class="grid grid-cols-2 gap-5" id="grid-grupos">
                            <!-- 1. ROSSVAL -->
                            <div class="grupo-item flex flex-col items-center text-center">
                                <div class="relative w-full aspect-square mb-3">
                                    <div class="absolute inset-0 translate-x-1.5 translate-y-1.5 rounded-lg bg-[#122a4d]/10"></div>
                                    <div class="relative h-full p-[3px] bg-gradient-to-br from-[#c9a961]/80 via-[#122a4d]/30 to-[#c9a961]/80 rounded-lg shadow-md">
                                        <div class="h-full p-[2px] bg-white rounded-lg">
                                            <img
                                                src="/imagenes/rossval.png"
                                                alt="Rossval"
                                                class="w-full h-full object-cover rounded-lg"
                                            />
                                        </div>
                                    </div>
                                </div>
                                <p class="font-cormorant-sc text-lg uppercase tracking-wide text-[#122a4d] font-semibold leading-tight">
                                    Rossval
                                </p>
                            </div>

                            <!-- 2. ALMA CUMBIA -->
                            <div class="grupo-item flex flex-col items-center text-center">
                                <div class="relative w-full aspect-square mb-3">
                                    <div class="absolute inset-0 translate-x-1.5 translate-y-1.5 rounded-lg bg-[#122a4d]/10"></div>
                                    <div class="relative h-full p-[3px] bg-gradient-to-br from-[#c9a961]/80 via-[#122a4d]/30 to-[#c9a961]/80 rounded-lg shadow-md">
                                        <div class="h-full p-[2px] bg-white rounded-lg">
                                            <img
                                                src="/imagenes/alma%20cumbia.png"
                                                alt="Alma Cumbia"
                                                class="w-full h-full object-cover rounded-lg"
                                            />
                                        </div>
                                    </div>
                                </div>
                                <p class="font-cormorant-sc text-lg uppercase tracking-wide text-[#122a4d] font-semibold leading-tight">
                                    Alma Cumbia
                                </p>
                            </div>

                            <!-- 3. MISKY PACHA -->
                            <div class="grupo-item flex flex-col items-center text-center">
                                <div class="relative w-full aspect-square mb-3">
                                    <div class="absolute inset-0 translate-x-1.5 translate-y-1.5 rounded-lg bg-[#122a4d]/10"></div>
                                    <div class="relative h-full p-[3px] bg-gradient-to-br from-[#c9a961]/80 via-[#122a4d]/30 to-[#c9a961]/80 rounded-lg shadow-md">
                                        <div class="h-full p-[2px] bg-white rounded-lg">
                                            <img
                                                src="/imagenes/misky%20pacha.png"
                                                alt="Misky Pacha"
                                                class="w-full h-full object-cover rounded-lg"
                                            />
                                        </div>
                                    </div>
                                </div>
                                <p class="font-cormorant-sc text-lg uppercase tracking-wide text-[#122a4d] font-semibold leading-tight">
                                    Misky Pacha
                                </p>
                            </div>

                            <!-- 4. PANTERA -->
                            <div class="grupo-item flex flex-col items-center text-center">
                                <div class="relative w-full aspect-square mb-3">
                                    <div class="absolute inset-0 translate-x-1.5 translate-y-1.5 rounded-lg bg-[#122a4d]/10"></div>
                                    <div class="relative h-full p-[3px] bg-gradient-to-br from-[#c9a961]/80 via-[#122a4d]/30 to-[#c9a961]/80 rounded-lg shadow-md">
                                        <div class="h-full p-[2px] bg-white rounded-lg">
                                            <img
                                                src="/imagenes/pantera.png"
                                                alt="Pantera"
                                                class="w-full h-full object-cover rounded-lg"
                                            />
                                        </div>
                                    </div>
                                </div>
                                <p class="font-cormorant-sc text-lg uppercase tracking-wide text-[#122a4d] font-semibold leading-tight">
                                    Pantera
                                </p>
                            </div>

                            <!-- 5. ANDES BOLIVIA -->
                            <div class="grupo-item flex flex-col items-center text-center">
                                <div class="relative w-full aspect-square mb-3">
                                    <div class="absolute inset-0 translate-x-1.5 translate-y-1.5 rounded-lg bg-[#122a4d]/10"></div>
                                    <div class="relative h-full p-[3px] bg-gradient-to-br from-[#c9a961]/80 via-[#122a4d]/30 to-[#c9a961]/80 rounded-lg shadow-md">
                                        <div class="h-full p-[2px] bg-white rounded-lg">
                                            <img
                                                src="/imagenes/andes%20boilvia.png"
                                                alt="Andes Bolivia"
                                                class="w-full h-full object-cover rounded-lg"
                                            />
                                        </div>
                                    </div>
                                </div>
                                <p class="font-cormorant-sc text-lg uppercase tracking-wide text-[#122a4d] font-semibold leading-tight">
                                    Andes Bolivia
                                </p>
                            </div>

                            <!-- 6. PAPI MURILLO -->
                            <div class="grupo-item flex flex-col items-center text-center">
                                <div class="relative w-full aspect-square mb-3">
                                    <div class="absolute inset-0 translate-x-1.5 translate-y-1.5 rounded-lg bg-[#122a4d]/10"></div>
                                    <div class="relative h-full p-[3px] bg-gradient-to-br from-[#c9a961]/80 via-[#122a4d]/30 to-[#c9a961]/80 rounded-lg shadow-md">
                                        <div class="h-full p-[2px] bg-white rounded-lg">
                                            <img
                                                src="/imagenes/papi%20murillo.png"
                                                alt="Papi Murillo"
                                                class="w-full h-full object-cover rounded-lg"
                                            />
                                        </div>
                                    </div>
                                </div>
                                <p class="font-cormorant-sc text-lg uppercase tracking-wide text-[#122a4d] font-semibold leading-tight">
                                    Papi Murillo
                                </p>
                            </div>
                        </div>

                        <!-- SEPARADOR FINAL -->
                        <div class="flex items-center justify-center gap-3 mt-6">
                            <div class="flex-1 h-px bg-[#122a4d]/20"></div>
                            <span class="text-[#122a4d]/40 text-xs">✦</span>
                            <div class="flex-1 h-px bg-[#122a4d]/20"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.fromTo(
                "#boton-decorativo-grupos",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-grupos-musicales",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            gsap.fromTo(
                "#card-principal-grupos",
                { opacity: 0, y: 50, scale: 0.95 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-grupos-musicales",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            gsap.fromTo(
                "#titulo-grupos",
                { opacity: 0, y: -20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-grupos-musicales",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            gsap.fromTo(
                "#subtitulo-grupos",
                { opacity: 0, y: -10 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.1,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-grupos-musicales",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            gsap.fromTo(
                "#separador-grupos",
                { opacity: 0, scaleX: 0 },
                {
                    opacity: 1,
                    scaleX: 1,
                    duration: 0.7,
                    delay: 0.2,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-grupos-musicales",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            gsap.fromTo(
                "#grid-grupos .grupo-item",
                { opacity: 0, y: 24, scale: 0.9 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 0.6,
                    stagger: 0.08,
                    delay: 0.25,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-grupos-musicales",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );
        });
    }
</script>

<style>
    .font-cormorant-sc {
        font-family: "Cormorant SC", serif;
    }
</style>
