<!-- ═══════════════════════════════════════════════════════════ --><!-- 📅 SECCIÓN: ITINERARIO                                      --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- 📇 CARD DE ITINERARIO -->
        <div class="flex justify-center">
            <div class="relative w-[280px]" id="card-itinerario">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-itinerario">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-itinerario"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo itinerario"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Contenido de la card -->
                    <div class="relative px-6 pt-16 pb-10 z-10">
                        <!-- TÍTULO PRINCIPAL -->
                        <div class="text-center mb-8">
                            <h2
                                class="font-great-vibes text-[2.25rem] text-[#122a4d]"
                                id="titulo-itinerario"
                            >
                                Itinerario
                            </h2>
                        </div>

                        <!-- EVENTO 1: CEREMONIA -->
                        <div class="flex items-start gap-4 mb-5" id="evento-1">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/iglesia.png"
                                    alt="Ceremonia"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] text-[#122a4d] leading-none mb-1"
                                >
                                    Ceremonia
                                </h3>
                                <p class="font-crimson text-lg text-[#122a4d]">
                                    09:30 Hrs.
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 2: LLEGADA AL SALÓN -->
                        <div class="flex items-start gap-4 mb-5" id="evento-2">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/recepcion.png"
                                    alt="Llegada al Salón"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] text-[#122a4d] leading-none mb-1"
                                >
                                    Llegada al Salón
                                </h3>
                                <p class="font-crimson text-lg text-[#122a4d]">
                                    16:00 Hrs.
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 3: VALS -->
                        <div class="flex items-start gap-4 mb-5" id="evento-3">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/vals.png"
                                    alt="Vals"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] text-[#122a4d] leading-none mb-1"
                                >
                                    Vals
                                </h3>
                                <p class="font-crimson text-lg text-[#122a4d]">
                                    17:00 Hrs.
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 4: CENA -->
                        <div class="flex items-start gap-4 mb-5" id="evento-4">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/cena.png"
                                    alt="Cena"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] text-[#122a4d] leading-none mb-1"
                                >
                                    Cena
                                </h3>
                                <p class="font-crimson text-lg text-[#122a4d]">
                                    19:45 Hrs.
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 5: TORTA - BOUQUET -->
                        <div class="flex items-start gap-4 mb-5" id="evento-5">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/torta.png"
                                    alt="Torta - Bouquet"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] text-[#122a4d] leading-none mb-1"
                                >
                                    Torta - Bouquet
                                </h3>
                                <p class="font-crimson text-lg text-[#122a4d]">
                                    22:00 Hrs.
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 6: FELICES POR SIEMPRE -->
                        <div class="flex items-start gap-4" id="evento-6">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/despedida.png"
                                    alt="Felices por siempre"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] text-[#122a4d] leading-none mb-1"
                                >
                                    Felices por siempre
                                </h3>
                                <p class="font-crimson text-lg text-[#122a4d]">
                                    00:00 Hrs.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎨 ESTILOS PARA LOS ICONOS                                  -->
<!-- ═══════════════════════════════════════════════════════════ -->
<style>
    .icono-itinerario {
        filter: brightness(0) saturate(100%) invert(14%) sepia(50%)
            saturate(1847%) hue-rotate(188deg) brightness(95%) contrast(95%);
    }
</style>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP - SOLO UNA VEZ AL BAJAR            -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // Animación del botón decorativo
            gsap.fromTo(
                "#boton-decorativo-itinerario",
                {
                    opacity: 0,
                    scale: 0,
                    rotation: -180,
                },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-itinerario",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación de la card
            gsap.fromTo(
                "#card-principal-itinerario",
                {
                    opacity: 0,
                    y: 50,
                    scale: 0.95,
                },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-itinerario",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación del título
            gsap.fromTo(
                "#titulo-itinerario",
                {
                    opacity: 0,
                    y: -20,
                },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-itinerario",
                        start: "top 80%",
                        toggleActions: "play none none reset",
                    },
                },
            );

            // Animación de cada evento
            const eventos = [
                "#evento-1",
                "#evento-2",
                "#evento-3",
                "#evento-4",
                "#evento-5",
                "#evento-6",
            ];

            eventos.forEach((evento, index) => {
                gsap.fromTo(
                    evento,
                    {
                        opacity: 0,
                        x: -30,
                    },
                    {
                        opacity: 1,
                        x: 0,
                        duration: 0.6,
                        ease: "power2.out",
                        delay: index * 0.1,
                        scrollTrigger: {
                            trigger: "#card-itinerario",
                            start: "top 80%",
                            toggleActions: "play none none reset",
                        },
                    },
                );
            });
        });
    }
</script>
